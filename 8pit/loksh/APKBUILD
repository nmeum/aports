c276ad6c6815da3242f955dbe9702d90bdf8c186ce9e57c0945505b3939658c267c14649cdd2fcbabbd4ff9b1cada6dbadf985c94caf263ea2975db8366cbcca  bracketed-paste-mode.patch
"
